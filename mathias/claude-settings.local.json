{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Task",
      "WebSearch",
      "WebFetch",
      "Skill",
      "mcp__jetbrains__*",
      "mcp__idea__*",
      "mcp__ide__*",
      "mcp__context7__*",
      "Bash(nmcli connection:*)",
      "Bash(systemctl list-units:*)",
      "Bash(git config:*)",
      "Bash(unzip -l *)",
      "Bash(ifas-dev-tools/scripts/*)",
      "Bash(google-chrome-stable --remote-debugging-port=9222 *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rmdir *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(kill -9 *)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(git rebase *)",
      "Bash(git stash drop *)",
      "Bash(chmod 777 *)",
      "Bash(> *)"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [],
    "PermissionRequest": [],
    "UserPromptSubmit": [],
    "Stop": []
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false
  },
  "outputStyle": "default",
  "plansDirectory": "~/dev/projects/ifas13-agents/mathias/plans"
